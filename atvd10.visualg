// QUESTÃO 10
algoritmo "questao10"
var
m: vetor[1..3,1..4] de real
i, j: inteiro
soma, media: real
inicio
para i de 1 ate 3 faca
para j de 1 ate 4 faca
leia(m[i,j])
fimpara
fimpara

para i de 1 ate 3 faca
soma <- 0

para j de 1 ate 4 faca
soma <- soma + m[i,j]
fimpara

media <- soma / 4
escreval("Media da linha ", i, " = ", media:0:2)
fimpara
fimalgoritmo